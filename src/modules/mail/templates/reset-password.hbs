<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f4f4; padding: 20px; }
        .container { background-color: #fff; padding: 30px; border-radius: 8px; max-width: 500px; margin: auto; }
        .code { font-size: 24px; font-weight: bold; color: #333; letter-spacing: 2px; text-align: center; margin: 20px 0; background: #eee; padding: 10px; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Password Reset Request</h2>
        <p>You requested to reset your password. Use the code below to complete the process:</p>
        
        <!-- Handlebars injects the 'code' variable here -->
        <div class="code">{{ code }}</div> 
        
        <p>This code will expire in 15 minutes.</p>
        <p>If you didn't request this, you can safely ignore this email.</p>
        <p>Need help? Contact <a href="mailto:{{ supportEmail }}">{{ supportEmail }}</a></p>
    </div>
</body>
</html>