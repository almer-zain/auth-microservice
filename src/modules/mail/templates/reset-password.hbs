<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        /* Base Reset */
        body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
        body { 
            margin: 0; 
            padding: 0; 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; 
            background-color: #f3f4f6; /* Soft modern gray background */
            color: #374151; /* Dark gray for high readability */
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }
        
        /* Layout */
        .wrapper {
            width: 100%;
            background-color: #f3f4f6;
            padding: 40px 20px;
            box-sizing: border-box;
        }
        .container {
            max-width: 560px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05); /* Soft shadow */
        }

        /* Header Image */
        .header-image {
            width: 100%;
            height: auto;
            display: block;
            border-bottom: 1px solid #f3f4f6;
        }

        /* Content Area */
        .content {
            padding: 40px 32px;
        }
        h2 {
            margin-top: 0;
            color: #111827; /* Near black for headings */
            font-size: 24px;
            font-weight: 600;
        }
        p {
            margin: 0 0 16px 0;
            font-size: 16px;
        }

        /* The Code Box */
        .code-wrapper {
            text-align: center;
            margin: 32px 0;
        }
        .code-box {
            display: inline-block;
            background-color: #e0e7ff; /* Soft corporate indigo background */
            color: #3730a3; /* Deep indigo text */
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 8px;
            padding: 16px 32px;
            border-radius: 8px;
            border: 2px dashed #a5b4fc; /* Dashed border to indicate it's a code */
        }

        /* Security Notice Box */
        .security-notice {
            font-size: 14px;
            color: #6b7280;
            background-color: #f9fafb;
            padding: 16px;
            border-radius: 8px;
            margin-top: 32px;
            border-left: 4px solid #d1d5db;
        }
        .security-notice p {
            margin: 0;
        }

        /* Footer */
        .footer {
            padding: 24px 32px;
            background-color: #f9fafb;
            border-top: 1px solid #e5e7eb;
            text-align: center;
        }
        .footer p {
            margin: 0 0 8px 0;
            font-size: 14px;
            color: #6b7280;
        }
        .footer a {
            color: #4f46e5; /* Brand color link */
            text-decoration: none;
            font-weight: 500;
        }
        .footer a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            
            <!-- Placeholder Header Image (Change the URL later to your company logo/banner) -->
            <img src="https://placehold.co/600x120/4F46E5/FFFFFF?text=Company+Logo" alt="Company Logo" class="header-image">
            
            <div class="content">
                <h2>Reset Your Password</h2>
                <p>Hello,</p>
                <p>We received a request to reset the password for your account. Please use the verification code below to complete the process.</p>
                
                <!-- The Code -->
                <div class="code-wrapper">
                    <div class="code-box">{{ code }}</div>
                </div>
                
                <p><strong>Note:</strong> This code will expire in <strong>15 minutes</strong>.</p>
                
                <!-- Security Warning -->
                <div class="security-notice">
                    <p>If you didn't request a password reset, you can safely ignore this email. Your password will not be changed.</p>
                </div>
            </div>

            <!-- Footer -->
            <div class="footer">
                <p>Need help? Contact our support team at <br>
                    <a href="mailto:{{ supportEmail }}">{{ supportEmail }}</a>
                </p>
                <p>&copy; {{ copyrightNoticeYear }} {{ companyName }}. All rights reserved.</p>
            </div>
        </div>
    </div>
</body>
</html>