## App
APP_NAME="MyApp"
NODE_ENV=development
PORT=3000
FRONTEND_URL="http://localhost:3000"

## JWT 
JWT_ACCESS_SECRET="your-secret-key"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_SECRET="another-long-secret-key-for-refresh"
JWT_REFRESH_EXPIRY="7d"

## DB
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=''
DB_PASSWORD=''
DB_NAME=blog
DB_SYNCHRONIZE=false

## RATE LIMITER
RATELIMIT_TTL=60000
RATELIMIT_MAX=10
PORT=3000
FRONTEND_URL="http://localhost:3000"

## Cache
CACHE_TTL=600

## Redis
USE_REDIS=false
REDIS_URL="redis://localhost:6379"

## Mail
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass
MAIL_FROM="noreply@mymicroservice.com"
SMTP_SECURE=true
SUPPORT_EMAIL=your_support_email
EMAIL_EXPIRY=900000

## Company Info
COMPANY_NAME="Your Company"
COPYRIGHT_YEAR=2026