# ==============================================================================
# APP CONFIGURATION
# ==============================================================================
APP_NAME="Auth Service"
NODE_ENV=development
PORT=3000
FRONTEND_URL="http://localhost:3000"

# ==============================================================================
# SECURITY / JWT
# ==============================================================================
JWT_ACCESS_SECRET="generate_a_long_random_string_here"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_SECRET="generate_another_long_random_string_here"
JWT_REFRESH_EXPIRY="7d"

# ==============================================================================
# DATABASE (PostgreSQL)
# ==============================================================================
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=auth_service
DB_SYNCHRONIZE=false

# ==============================================================================
# RATE LIMITER & CACHE
# ==============================================================================
RATELIMIT_TTL=60000
RATELIMIT_MAX=10
CACHE_TTL=600

# ==============================================================================
# REDIS
# ==============================================================================
USE_REDIS=false
REDIS_URL="redis://localhost:6379"

# ==============================================================================
# MAIL (SMTP)
# ==============================================================================
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Your Company <noreply@your-company.com>"
SMTP_SECURE=false 
SUPPORT_EMAIL="support@your-company.com"
EMAIL_EXPIRY=900000

# ==============================================================================
# COMPANY INFO
# ==============================================================================
COMPANY_NAME="Your Company"
COPYRIGHT_YEAR=2024

# ==============================================================================
# CAPTCHA
# ==============================================================================
CAPTCHA_ENABLED=false
CAPTCHA_SECRET="1x0000000000000000000000000000000AA"